  "collaborative_security": {
    "model": "2-of-3",
    "version": "0.0.1",
    "keys": {
      "device": "04a1b2c3... (P-256, ECC608)",
      "server": "0xFleetServerAddress (secp256k1)",
      "operators": [
        { "address": "0xTechnician1", "role": "field_tech" },
        { "address": "0xFleetManager1", "role": "fleet_manager" },
