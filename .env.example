# Copy this file to .env for local testing only.
#
# In GitHub Actions:
#   - Set API keys as repository secrets
#   - Set model names as optional repository variables (vars)
#
# The workflow prefers Anthropic when both keys are present.

# Anthropic (preferred)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
